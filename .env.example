# ============================================
# AWS EC2 SQL Server (Epic Clarity source)
# ============================================
SQLSERVER_HOST=<your-ec2-public-ip>
SQLSERVER_PORT=1433
SQLSERVER_USERNAME=admin
SQLSERVER_PASSWORD=<your-secure-password>
SQLSERVER_DATABASE=HEALTHCAREDEMO

# ============================================
# Fivetran (https://fivetran.com/account/settings)
# ============================================
FIVETRAN_API_KEY=<your-api-key>
FIVETRAN_API_SECRET=<your-api-secret>
FIVETRAN_CONNECTOR_ID=<your-sqlserver-connector-id>
FIVETRAN_DESTINATION_ID=<your-snowflake-destination-id>

# ============================================
# Snowflake destination + dbt target
# ============================================
SNOWFLAKE_ACCOUNT=<your-account-locator>     # e.g. abc12345.us-east-1
SNOWFLAKE_USER=<your-username>
SNOWFLAKE_PASSWORD=<your-password>
SNOWFLAKE_ROLE=JASON_CHLETSOS_DBT_ROLE
SNOWFLAKE_DATABASE=JASON_CHLETSOS_EPIC
SNOWFLAKE_WAREHOUSE=JASON_CHLETSOS_TRANSFORM_WH
SNOWFLAKE_QUERY_WH=JASON_CHLETSOS_QUERY_WH

# Source schema where Fivetran lands CDC data
FIVETRAN_RAW_SCHEMA=JASON_CHLETSOS_EHR_DEMO
SCHEMA_NAME=CLARITY
